# .envrc
GMV_ROOT="$(pwd)"
THIRD_PARTY_DIR="$GMV_ROOT/third_party"

# 找到 ffmpeg dist 目录
FFMPEG_ROOT="$(find "$THIRD_PARTY_DIR" -maxdepth 2 -type d -name dist -path '*/ffmpeg-*/dist' 2>/dev/null | sort -V | tail -n 1)"

if [[ -n "$FFMPEG_ROOT" && -d "$FFMPEG_ROOT/lib/pkgconfig" ]]; then
    export FFMPEG_ROOT
    export PKG_CONFIG_PATH="$FFMPEG_ROOT/lib/pkgconfig:$PKG_CONFIG_PATH"
    export LD_LIBRARY_PATH="$FFMPEG_ROOT/lib:$LD_LIBRARY_PATH"
    export LIBRARY_PATH="$FFMPEG_ROOT/lib:$LIBRARY_PATH"
    export C_INCLUDE_PATH="$FFMPEG_ROOT/include:$C_INCLUDE_PATH"
    export CPLUS_INCLUDE_PATH="$FFMPEG_ROOT/include:$CPLUS_INCLUDE_PATH"
    echo "[OK] FFmpeg environment loaded via direnv"
    echo "FFMPEG_ROOT=$FFMPEG_ROOT"
else
    echo "[WARN] FFmpeg dist not found, run: ./stream/build_ffmpeg_min_bootstrap.sh"
fi
